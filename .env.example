# ── GenAI Systems Lab — environment variables ────────────────────────────────
# Copy this file to .env.local and fill in your values.
# None of these are required — the app works without all of them.

# PostHog analytics (optional)
# Get your project key from https://posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_KEY
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Feedback form URL (optional — defaults to placeholder)
# Create a Google Form with the recommended questions from README.md
VITE_FEEDBACK_URL=https://forms.gle/REPLACE_WITH_YOUR_FORM_ID
